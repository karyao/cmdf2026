{
  "expo": {
    "name": "Day in the Life",
    "slug": "day-in-the-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f4f6ff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cmdf2026.dayinthelife"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.cmdf2026.dayinthelife"
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "expo-video"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
